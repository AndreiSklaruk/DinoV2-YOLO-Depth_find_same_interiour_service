# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ─── Виртуальное окружение ────────────────────────────────────────────────────
# .venv создаётся автоматически через `uv sync` — не нужно в git
.venv/
venv/
env/
ENV/

# ─── ML модели (тяжёлые файлы, не нужны в git) ───────────────────────────────
*.pt
*.pth
*.bin
*.onnx
*.safetensors
*.ckpt

# ─── HuggingFace кэш ──────────────────────────────────────────────────────────
.cache/
~/.cache/huggingface/

# ─── FAISS индексы (генерируются через build_*.py) ───────────────────────────
index/faiss.index
index/depth.index
index/*.index
index/*.npy

# ─── База данных изображений (не для git) ────────────────────────────────────
database/

# ─── Загруженные пользователями файлы ────────────────────────────────────────
uploads/

# ─── Ключи, токены, секреты ───────────────────────────────────────────────────
.env
.env.*
*.env
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
secrets/
credentials/
config/secrets.json
*secret*
*token*
*api_key*
.netrc
*.htpasswd

# ─── Логи ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── IDE / Редакторы ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Временные файлы ──────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
scratch.py
test_inference.py

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb
